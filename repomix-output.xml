const express = require('express');
const router = express.Router();
const usersRepo = require('../repositories/usersRepository');

router.post('/login', async (req, res) => {
    const { username } = req.body;

    if (!username) {
        return res.status(400).json({ message: 'Numele de utilizator este obligatoriu!' });
    }

    try {
        // Căutare utilizator
        let user = await usersRepo.findByUsername(username);
        
        // Dacă nu există, se creaza automat 
        if (!user) {
            user = await usersRepo.create(username);
        }

        res.status(200).json(user);
    } catch (error) {
        res.status(500).json({ message: 'Eroare la procesarea utilizatorului.' });
    }
});

module.exports = router;
